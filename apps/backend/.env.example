# Copy this file to .env and fill in real values.
# Required -- the server refuses to start without these (see src/config/env.ts).

# Port the backend listens on. 5001 is the project default; every frontend
# (apps/mobile, apps/admin, apps/vendor) falls back to this same port in dev.
PORT=5001

# Postgres connection string (Prisma). In production this points at the
# Hostinger PostgreSQL instance -- every app uses this same DATABASE_URL.
# IMPORTANT (production/Docker only): the backend runs inside a container,
# but Postgres runs natively on the VPS host -- `localhost`/`127.0.0.1` from
# inside the container means the container itself, not the host, so this
# will fail to connect. Use `host.docker.internal` instead (docker-compose.yml
# maps it to the host gateway via extra_hosts). Local (non-Docker) dev should
# keep using 127.0.0.1 as shown here.
DATABASE_URL="postgresql://postgres:password@127.0.0.1:5432/mechbazar?schema=public"

# Signs auth JWTs. Must be a real random secret in production -- the server
# refuses to boot in production with the shared local default value.
JWT_SECRET="supersecretkey123"

# Optional -- caching only. The server logs a warning and keeps running
# without Redis if this is unset or unreachable.
REDIS_URL="redis://127.0.0.1:6379"

# Dev convenience: accept a fixed OTP instead of sending real SMS. Never set
# this in production.
ALLOW_DEV_OTP_BYPASS=true
# Comma-separated list of phones the dev OTP bypass above applies to. Required
# in addition to ALLOW_DEV_OTP_BYPASS=true -- never a blanket bypass.
DEV_OTP_BYPASS_PHONES=

# TEST (default) verifies OTPs against the local PhoneOtp table and echoes the
# generated code back in POST /auth/send-otp's response for local testing
# without a real SMS provider (that echo is additionally hard-disabled outside
# NODE_ENV=production regardless of this value). PRODUCTION verifies a real
# Firebase phone-auth ID token instead, and requires FIREBASE_PROJECT_ID /
# FIREBASE_CLIENT_EMAIL / FIREBASE_PRIVATE_KEY to be set.
OTP_PROVIDER=TEST

# Optional -- when set, POST /upload (upload.controller.ts) saves files to
# this Firebase Storage bucket instead of the local uploads/ dir. Also
# requires FIREBASE_PROJECT_ID / FIREBASE_CLIENT_EMAIL /
# FIREBASE_PRIVATE_KEY (same firebase-admin credentials OTP_PROVIDER=PRODUCTION
# uses). Example: mech-bazar.firebasestorage.app
FIREBASE_STORAGE_BUCKET=

# Optional -- comma-separated list of allowed browser origins for CORS. Unset
# (default) allows all origins, which is the current behavior in every
# deployed environment; set this to lock the API down to known admin/vendor
# web origins.
CORS_ALLOWED_ORIGINS=

NODE_ENV=development
