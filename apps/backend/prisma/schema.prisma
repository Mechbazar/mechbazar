generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  CUSTOMER
  ADMIN
  SUPER_ADMIN
  OPERATIONS_MANAGER
  INVENTORY_MANAGER
  VENDOR_MANAGER
  FINANCE_MANAGER
  CUSTOMER_SUPPORT
  VENDOR
  DELIVERY_PARTNER
  SERVICE_TECHNICIAN
}

enum VendorStatus {
  PENDING
  UNDER_VERIFICATION
  APPROVED
  REJECTED
  SUSPENDED
  BLOCKED
  INACTIVE
}

enum RiderStatus {
  PENDING
  UNDER_VERIFICATION
  RESUBMISSION_REQUIRED
  APPROVED
  REJECTED
  SUSPENDED
  BLOCKED
  INACTIVE
}

enum OrderStatus {
  PLACED
  ACCEPTED
  PACKING
  PICKUP
  ON_THE_WAY
  DELIVERED
  CANCELLED
  RETURNED
}

enum TechnicianStatus {
  PENDING
  UNDER_VERIFICATION
  RESUBMISSION_REQUIRED
  APPROVED
  REJECTED
  SUSPENDED
  BLOCKED
  INACTIVE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  MECHANIC_ASSIGNED
  MECHANIC_ACCEPTED
  MECHANIC_ON_THE_WAY
  ARRIVED
  WORK_STARTED
  COMPLETED
  CANCELLED
  REJECTED
}

enum AccountType {
  RETAIL
  WHOLESALE
  BOTH
}

enum VehicleType {
  CAR
  BIKE
}

model User {
  id        String   @id @default(uuid())
  phone     String   @unique
  email     String?  @unique
  name      String?
  password  String?
  role      Role     @default(CUSTOMER)
  
  // B2B & Mode Fields
  accountType        AccountType @default(RETAIL)
  companyName        String?
  contactPerson      String?
  gstNumber          String?
  businessType       String?
  city               String?
  state              String?
  isBusinessVerified Boolean     @default(false)

  avatar    String?
  gender    String?
  dob       String?
  wallet    Float    @default(0.0)
  expoPushToken String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses     Address[]
  userVehicles  UserVehicle[]
  orders        Order[]
  reviews       Review[]
  wishlists     Wishlist[]
  notifications Notification[]
  auditLogs     AuditLog[]
  supportTickets SupportTicket[]
  stockMovements StockMovement[]
  vendorProfile Vendor?
  deliveryProfile DeliveryPartner?
  technicianProfile ServiceTechnician?
  serviceBookings   ServiceBooking[]
  serviceReviews    ServiceReview[]
}

model Vendor {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])
  storeName     String
  gstNumber     String?
  panNumber     String?
  businessType  String?
  categories    String[] 
  walletBalance Float    @default(0.0)
  status        VendorStatus @default(PENDING)
  isActive      Boolean  @default(true)
  
  products      Product[]
  documents     VendorDocument[]
  bankAccounts  VendorBankAccount[]
  settlements   VendorSettlement[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
}

model VendorDocument {
  id          String   @id @default(uuid())
  vendorId    String
  vendor      Vendor   @relation(fields: [vendorId], references: [id])
  type        String   // GST, PAN, AADHAAR, SHOP_PHOTO, OWNER_PHOTO, BUSINESS_LICENSE, CANCELLED_CHEQUE
  url         String
  status      String   @default("PENDING") // PENDING, VERIFIED, REJECTED
  uploadedAt  DateTime @default(now())
}

model VendorBankAccount {
  id                String   @id @default(uuid())
  vendorId          String
  vendor            Vendor   @relation(fields: [vendorId], references: [id])
  accountHolderName String
  bankName          String
  accountNumber     String
  ifscCode          String
  isVerified        Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model VendorSettlement {
  id            String   @id @default(uuid())
  vendorId      String
  vendor        Vendor   @relation(fields: [vendorId], references: [id])
  amount        Float
  status        String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  transactionId String?
  date          DateTime @default(now())
}

model DeliveryPartner {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])
  vehicleType   String
  licenseNumber String
  isActive      Boolean  @default(false)
  isOnline      Boolean  @default(false)
  currentLat    Float?
  currentLng    Float?
  expoPushToken String?
  walletBalance Float    @default(0.0)

  // KYC / registration & verification (app self-registration path; admin
  // quick-created riders default straight to APPROVED, see createRider)
  status                     RiderStatus @default(PENDING)
  addressLine                String?
  city                       String?
  state                      String?
  pincode                    String?
  aadhaarNumber              String?
  vehicleModel               String?
  vehicleRegistrationNumber  String?
  insurancePolicyNumber      String?
  insuranceExpiry            DateTime?
  pucNumber                  String?
  pucExpiry                  DateTime?
  upiId                      String?
  emergencyContactName       String?
  emergencyContactPhone      String?
  submittedAt                DateTime?
  reviewedAt                 DateTime?
  remarks                    String?

  orders        Order[]
  bankAccounts  RiderBankAccount[]
  settlements   RiderSettlement[]
  documents     RiderDocument[]
}

model RiderDocument {
  id                String          @id @default(uuid())
  deliveryPartnerId String
  deliveryPartner   DeliveryPartner @relation(fields: [deliveryPartnerId], references: [id])
  type              String   // AADHAAR, DL_FRONT, DL_BACK, RC, INSURANCE, PUC, SELFIE, PROFILE_PHOTO
  filePath          String   // legacy disk path for pre-serverless rows; new rows store the original filename here for display only
  fileData          Bytes?   // file bytes, stored in Postgres instead of disk -- Vercel's serverless functions have no persistent filesystem, and this data is private KYC content that must not sit in public object storage
  mimeType          String?
  status            String   @default("PENDING") // PENDING, VERIFIED, REJECTED
  remarks           String?
  uploadedAt        DateTime @default(now())
}

model RiderBankAccount {
  id                String          @id @default(uuid())
  deliveryPartnerId String
  deliveryPartner   DeliveryPartner @relation(fields: [deliveryPartnerId], references: [id])
  accountHolderName String
  bankName          String
  accountNumber     String
  ifscCode          String
  isVerified        Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model RiderSettlement {
  id                String          @id @default(uuid())
  deliveryPartnerId String
  deliveryPartner   DeliveryPartner @relation(fields: [deliveryPartnerId], references: [id])
  amount            Float
  status            String          @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  transactionId     String?
  date              DateTime        @default(now())
}

model Address {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  line1     String
  line2     String?
  city      String
  state     String
  pincode   String
  lat       Float?
  lng       Float?
  isDefault Boolean  @default(false)
  orders    Order[]
  serviceBookings ServiceBooking[]
}

// =======================
// VEHICLE MASTER DATA
// =======================

model Manufacturer {
  id       String      @id @default(uuid())
  name     String
  type     VehicleType @default(CAR)
  logo     String?
  models   Model[]
  vehicles Vehicle[]

  // Honda/BMW/Suzuki sell both cars and bikes, so a brand is one row per type
  @@unique([name, type])
}

model Model {
  id             String       @id @default(uuid())
  manufacturerId String
  manufacturer   Manufacturer @relation(fields: [manufacturerId], references: [id])
  name           String
  variants       Variant[]
  vehicles       Vehicle[]
}

model Variant {
  id      String    @id @default(uuid())
  modelId String
  model   Model     @relation(fields: [modelId], references: [id])
  name    String
  vehicles Vehicle[]
}

model FuelType {
  id   String @id @default(uuid())
  name String @unique // e.g., Petrol, Diesel, CNG, EV
  vehicles Vehicle[]
}

model Vehicle {
  id             String       @id @default(uuid())
  manufacturerId String
  manufacturer   Manufacturer @relation(fields: [manufacturerId], references: [id])
  modelId        String
  model          Model        @relation(fields: [modelId], references: [id])
  variantId      String?
  variant        Variant?     @relation(fields: [variantId], references: [id])
  fuelTypeId     String
  fuelType       FuelType     @relation(fields: [fuelTypeId], references: [id])
  year           Int
  engineCc       Int?

  userVehicles           UserVehicle[]
  productCompatibilities ProductCompatibility[]

  @@unique([manufacturerId, modelId, variantId, fuelTypeId, year])
}

// =======================
// CUSTOMER'S GARAGE
// =======================

model UserVehicle {
  id                 String  @id @default(uuid())
  userId             String
  user               User    @relation(fields: [userId], references: [id])
  // Manufacturer/Model/Variant taxonomy is now seeded (see prisma/seed-vehicle-master.ts),
  // but garage vehicles still snapshot brand/model/etc. as plain strings rather than a
  // required Vehicle FK, same shape as ServiceBooking's vehicleType/vehicleBrand/vehicleModel
  // snapshot fields -- keeps a garage entry valid even for combinations (e.g. a variant/year
  // pairing) the taxonomy doesn't have an exact Vehicle row for. vehicleId stays optional,
  // populated opportunistically when a matching row exists.
  vehicleId          String?
  vehicle            Vehicle? @relation(fields: [vehicleId], references: [id])
  vehicleType        VehicleType
  brand              String
  model              String
  year               String?
  fuelType           String?
  engine             String?
  transmission       String?
  trim               String?
  registrationNumber String?
  nickname           String?
  isDefault          Boolean @default(false)
  serviceBookings    ServiceBooking[]
}

// =======================
// PRODUCTS & CATALOG
// =======================

model Category {
  id       String    @id @default(uuid())
  name     String
  image    String?
  icon     String?   @default("📦")
  status   String?   @default("Active")
  vehicleType VehicleType @default(CAR)
  parentId String?
  parent   Category? @relation("CategoryToCategory", fields: [parentId], references: [id])
  children Category[] @relation("CategoryToCategory")
  products Product[]

  @@unique([name, vehicleType])
}

model Brand {
  id       String    @id @default(uuid())
  name     String    @unique
  logo     String?
  vehicleType VehicleType @default(CAR)
  products Product[]
}

model Product {
  id          String   @id @default(uuid())
  vendorId    String
  vendor      Vendor   @relation(fields: [vendorId], references: [id])
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  brandId     String
  brand       Brand    @relation(fields: [brandId], references: [id])
  
  name        String
  description String
  mrp         Float
  price       Float
  stock       Int      @default(0)
  images      String[]
  oemNumber   String?
  partNumber  String?
  status      String   @default("APPROVED") // PENDING, APPROVED, REJECTED
  vehicleType        VehicleType  @default(CAR)
  discountPrice      Float?
  isFeatured         Boolean  @default(false)
  isDeal             Boolean  @default(false)
  salesCount         Int      @default(0)
  compatibleModels   String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  compatibilities ProductCompatibility[]
  orderItems      OrderItem[]
  reviews         Review[]
  wishlists       Wishlist[]
  inventories     Inventory[]
  stockTransfers  StockTransfer[]
  poItems         PurchaseOrderItem[]

  @@index([vendorId])
  @@index([categoryId])
}

model ProductCompatibility {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])
  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  @@unique([productId, vehicleId])
}

// =======================
// ORDERS & PAYMENTS
// =======================

model Order {
  id                String           @id @default(uuid())
  userId            String
  user              User             @relation(fields: [userId], references: [id])
  addressId         String
  address           Address          @relation(fields: [addressId], references: [id])
  deliveryPartnerId String?
  deliveryPartner   DeliveryPartner? @relation(fields: [deliveryPartnerId], references: [id])
  couponId          String?
  coupon            Coupon?          @relation(fields: [couponId], references: [id])
  
  status            OrderStatus      @default(PLACED)
  totalAmount       Float
  discountAmount    Float            @default(0)
  deliveryFee       Float            @default(0)
  finalAmount       Float

  proofImageUrl     String?
  codCollected      Boolean          @default(false)
  issueReason       String?

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  items             OrderItem[]
  payment           Payment?

  @@index([status])
  @@index([userId])
  @@index([deliveryPartnerId])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float

  @@index([productId])
}

model Payment {
  id            String   @id @default(uuid())
  // Exactly one of orderId/serviceBookingId is set per row -- enforced in
  // application code (order.controller.ts / service.controller.ts each create
  // Payment as a nested create under their own entity), not at the DB level.
  orderId       String?  @unique
  order         Order?   @relation(fields: [orderId], references: [id])
  serviceBookingId String? @unique
  serviceBooking   ServiceBooking? @relation(fields: [serviceBookingId], references: [id])
  method        String   // e.g., UPI, CARD, COD
  status        String   // PENDING, SUCCESS, FAILED, REFUNDED
  transactionId String?
  amount        Float
  createdAt     DateTime @default(now())
}

model Coupon {
  id            String   @id @default(uuid())
  code          String   @unique
  discountType  String   // PERCENTAGE, FLAT
  discountValue Float
  minOrderValue Float    @default(0)
  vehicleType   VehicleType? // null = applies to both CAR and BIKE orders
  isActive      Boolean  @default(true)
  orders        Order[]
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  body      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// =======================
// ADMIN & LOGS
// =======================

model AuditLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  action      String
  entity      String
  entityId    String?
  details     String?  @db.Text
  ipAddress   String?
  createdAt   DateTime @default(now())
}

model Banner {
  id          String   @id @default(uuid())
  title       String
  image       String
  type        String   @default("HOMEPAGE") // HOMEPAGE, CATEGORY, PROMO
  link        String?
  vehicleType  VehicleType @default(CAR)
  buttonText   String?
  redirectLink String?
  isActive    Boolean  @default(true)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SupportTicket {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  subject     String
  description String   @db.Text
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  priority    String   @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// =======================
// INVENTORY & WAREHOUSE
// =======================

model Warehouse {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  address     String
  managerName String?
  phone       String?
  capacity    Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  inventory   Inventory[]
  transfersFrom StockTransfer[] @relation("TransferFrom")
  transfersTo   StockTransfer[] @relation("TransferTo")
}

model Supplier {
  id             String   @id @default(uuid())
  name           String
  companyName    String
  contactPerson  String?
  phone          String?
  email          String?
  gstNumber      String?
  address        String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  purchaseOrders PurchaseOrder[]
}

model Inventory {
  id             String    @id @default(uuid())
  productId      String
  product        Product   @relation(fields: [productId], references: [id])
  warehouseId    String
  warehouse      Warehouse @relation(fields: [warehouseId], references: [id])
  
  batchNumber    String?
  availableStock Int       @default(0)
  reservedStock  Int       @default(0)
  damagedStock   Int       @default(0)
  reorderLevel   Int       @default(0)
  unitCost       Float     @default(0)
  
  mfgDate        DateTime?
  expiryDate     DateTime?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  movements      StockMovement[]
  
  @@unique([productId, warehouseId])
}

model StockMovement {
  id           String    @id @default(uuid())
  inventoryId  String
  inventory    Inventory @relation(fields: [inventoryId], references: [id])
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  
  action       String    // PURCHASE, SALE, RETURN, DAMAGE, ADJUSTMENT, TRANSFER
  prevQuantity Int
  newQuantity  Int
  quantityDiff Int       // Can be negative or positive
  reason       String?
  
  createdAt    DateTime  @default(now())
}

model StockTransfer {
  id             String    @id @default(uuid())
  productId      String
  product        Product   @relation(fields: [productId], references: [id])
  fromWarehouseId String
  fromWarehouse  Warehouse @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouseId  String
  toWarehouse    Warehouse @relation("TransferTo", fields: [toWarehouseId], references: [id])
  
  quantity       Int
  status         String    @default("PENDING") // PENDING, APPROVED, SHIPPED, COMPLETED, CANCELLED
  transferDate   DateTime?
  receivedDate   DateTime?
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model PurchaseOrder {
  id             String    @id @default(uuid())
  supplierId     String
  supplier       Supplier  @relation(fields: [supplierId], references: [id])
  status         String    @default("DRAFT") // DRAFT, APPROVED, ORDERED, RECEIVED, COMPLETED, CANCELLED
  
  totalCost      Float     @default(0)
  taxAmount      Float     @default(0)
  expectedDate   DateTime?
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  items          PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  
  quantity        Int
  unitCost        Float
  taxAmount       Float         @default(0)
  receivedQty     Int           @default(0)
}

model Offer {
  id            String   @id @default(uuid())
  title         String
  description   String?
  image         String?
  discountType  String   @default("PERCENTAGE") // PERCENTAGE, FLAT
  discountValue Float
  minOrderValue Float    @default(0)
  code          String?  @unique
  vehicleType   VehicleType  @default(CAR)
  isActive      Boolean  @default(true)
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// =======================
// DOORSTEP SERVICES
// =======================

model ServiceTechnician {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])
  specializations VehicleType[]
  isActive      Boolean  @default(false)
  isOnline      Boolean  @default(false)
  currentLat    Float?
  currentLng    Float?
  expoPushToken String?
  walletBalance Float    @default(0.0)
  rating        Float    @default(0)
  totalJobs     Int      @default(0)

  // KYC / registration & verification -- mirrors DeliveryPartner exactly.
  status                TechnicianStatus @default(PENDING)
  addressLine           String?
  city                  String?
  state                 String?
  pincode               String?
  aadhaarNumber         String?
  skills                String[]
  experienceYears       Int?
  emergencyContactName  String?
  emergencyContactPhone String?
  submittedAt           DateTime?
  reviewedAt            DateTime?
  remarks               String?

  bookings      ServiceBooking[]
  documents     TechnicianDocument[]
  bankAccounts  TechnicianBankAccount[]
  settlements   TechnicianSettlement[]
  reviews       ServiceReview[]
}

model TechnicianDocument {
  id            String            @id @default(uuid())
  technicianId  String
  technician    ServiceTechnician @relation(fields: [technicianId], references: [id])
  type          String   // AADHAAR, CERTIFICATION, SELFIE, PROFILE_PHOTO
  filePath      String   // original filename, display only -- bytes are the source of truth
  fileData      Bytes?   // stored in Postgres, not disk -- see RiderDocument for rationale (no persistent FS on Vercel serverless, and this is private KYC content)
  mimeType      String?
  status        String   @default("PENDING") // PENDING, VERIFIED, REJECTED
  remarks       String?
  uploadedAt    DateTime @default(now())
}

model TechnicianBankAccount {
  id                String            @id @default(uuid())
  technicianId      String
  technician        ServiceTechnician @relation(fields: [technicianId], references: [id])
  accountHolderName String
  bankName          String
  accountNumber     String
  ifscCode          String
  isVerified        Boolean           @default(false)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model TechnicianSettlement {
  id            String            @id @default(uuid())
  technicianId  String
  technician    ServiceTechnician @relation(fields: [technicianId], references: [id])
  amount        Float
  status        String            @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  transactionId String?
  date          DateTime          @default(now())
}

model ServiceCategory {
  id          String      @id @default(uuid())
  name        String
  icon        String?     @default("🔧")
  image       String?
  description String?
  vehicleType VehicleType @default(CAR)
  isEmergency Boolean     @default(false)
  status      String      @default("Active")
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  packages    ServicePackage[]
  bookings    ServiceBooking[]

  @@unique([name, vehicleType])
}

model ServicePackage {
  id               String          @id @default(uuid())
  categoryId       String
  category         ServiceCategory @relation(fields: [categoryId], references: [id])
  name             String
  description      String?
  image            String?
  price            Float
  discountPrice    Float?
  estimatedMinutes Int             @default(60)
  includedServices String[]
  isActive         Boolean         @default(true)
  isPopular        Boolean         @default(false)
  isRecommended    Boolean         @default(false)
  isEmergency      Boolean         @default(false)
  rating           Float           @default(0)
  reviewCount      Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  bookings         ServiceBooking[]
}

model TimeSlot {
  id                 String   @id @default(uuid())
  label              String   // e.g. "9:00 AM - 11:00 AM"
  startTime          String   // "09:00"
  endTime            String   // "11:00"
  maxBookingsPerSlot Int      @default(20)
  isActive           Boolean  @default(true)
  sortOrder          Int      @default(0)

  bookings           ServiceBooking[]
}

model ServiceBooking {
  id             String    @id @default(uuid())
  bookingNumber  String    @unique

  userId         String
  user           User      @relation(fields: [userId], references: [id])
  // The mobile "Garage" (UserVehicle) is currently a client-side/AsyncStorage-only
  // feature with no backend API writing to UserVehicle, and the Manufacturer/Model
  // master-data tables have no CAR/BIKE column and are unseeded -- so vehicle
  // details are snapshotted directly on the booking (like Order/OrderItem
  // snapshot price at order time) rather than hard-required via FK. userVehicleId
  // stays optional so a future Garage-sync API (Phase 2) can link back to it.
  userVehicleId  String?
  userVehicle    UserVehicle? @relation(fields: [userVehicleId], references: [id])
  vehicleType    VehicleType
  vehicleBrand   String
  vehicleModel   String
  vehicleFuelType String?
  vehicleRegistrationNumber String?

  categoryId     String
  category       ServiceCategory @relation(fields: [categoryId], references: [id])
  packageId      String
  package        ServicePackage  @relation(fields: [packageId], references: [id])

  technicianId   String?
  technician     ServiceTechnician? @relation(fields: [technicianId], references: [id])

  addressId      String
  address        Address   @relation(fields: [addressId], references: [id])

  scheduledDate  DateTime
  timeSlotId     String
  timeSlot       TimeSlot  @relation(fields: [timeSlotId], references: [id])

  issueDescription String?
  status         BookingStatus @default(PENDING)

  estimatedCost  Float
  additionalCost Float     @default(0)
  finalAmount    Float

  approvalStatus String?   // PENDING, APPROVED, REJECTED -- a non-blocking flag for
  // an in-flight additional-work-cost request while status stays WORK_STARTED; not
  // a booking status itself (see BookingStatus.REJECTED, which is a technician
  // declining the job, an unrelated concept despite the similar string).
  approvalNote   String?

  cancelReason   String?
  completedAt    DateTime?

  // Set when a technician calls the "Generate OTP" action from WORK_STARTED; the
  // customer reads the code aloud and the technician enters it to confirm
  // completion. Cleared once used. Never returned to the technician's own client.
  completionOtp             String?
  completionOtpGeneratedAt  DateTime?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  images         ServiceImage[]
  statusHistory  BookingStatusHistory[]
  messages       ServiceChatMessage[]
  payment        Payment?
  review         ServiceReview?
  invoice        ServiceInvoice?

  @@index([userId])
  @@index([technicianId])
  @@index([status])
  @@index([scheduledDate])
}

model BookingStatusHistory {
  id              String         @id @default(uuid())
  bookingId       String
  booking         ServiceBooking @relation(fields: [bookingId], references: [id])
  status          BookingStatus
  note            String?
  changedByUserId String?
  createdAt       DateTime       @default(now())
}

model ServiceChatMessage {
  id           String         @id @default(uuid())
  bookingId    String
  booking      ServiceBooking @relation(fields: [bookingId], references: [id])
  senderUserId String
  senderRole   String         // CUSTOMER, TECHNICIAN
  message      String
  createdAt    DateTime       @default(now())

  @@index([bookingId])
}

model ServiceImage {
  id             String         @id @default(uuid())
  bookingId      String
  booking        ServiceBooking @relation(fields: [bookingId], references: [id])
  fileData       Bytes?
  mimeType       String?
  type           String         // ISSUE, BEFORE, AFTER, ADDITIONAL_WORK
  uploadedByRole String         // CUSTOMER, TECHNICIAN
  createdAt      DateTime       @default(now())
}

model ServiceReview {
  id           String            @id @default(uuid())
  bookingId    String            @unique
  booking      ServiceBooking    @relation(fields: [bookingId], references: [id])
  userId       String
  user         User              @relation(fields: [userId], references: [id])
  technicianId String
  technician   ServiceTechnician @relation(fields: [technicianId], references: [id])
  rating       Int
  comment      String?
  createdAt    DateTime          @default(now())
}

model ServiceInvoice {
  id             String         @id @default(uuid())
  bookingId      String         @unique
  booking        ServiceBooking @relation(fields: [bookingId], references: [id])
  invoiceNumber  String         @unique
  subtotal       Float
  additionalCost Float          @default(0)
  discountAmount Float          @default(0)
  taxAmount      Float          @default(0)
  totalAmount    Float
  pdfUrl         String?
  createdAt      DateTime       @default(now())
}

model PhoneOtp {
  phone     String   @id
  otpHash   String
  expiresAt DateTime
  createdAt DateTime @default(now())
}
