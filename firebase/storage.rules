rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // All uploads go through apps/backend/src/controllers/upload.controller.ts
      // using the Admin SDK, which bypasses these rules entirely -- so writes
      // here are locked to nobody, and reads are public to match the public
      // URL this backend already returns.
      allow read: if true;
      allow write: if false;
    }
  }
}
